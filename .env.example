# ============================================================
# HireMate AI — 环境变量配置示例
# 复制本文件为 .env，填写实际值后启动项目
# ============================================================

# ── 数据库配置 ─────────────────────────────────────────────
# MySQL 连接信息（用户名、密码、库名）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hiremate
DB_USERNAME=root
DB_PASSWORD=你的MySQL密码

# ── Redis 配置 ─────────────────────────────────────────────
# 缓存与会话存储服务
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DATABASE=0
# Redis 密码（如未设置密码，留空即可）
# REDIS_PASSWORD=

# ── 服务器配置 ─────────────────────────────────────────────
# 后端服务端口（默认 8080）
SERVER_PORT=8080

# ── JWT 认证配置 ───────────────────────────────────────────
# ⚠️ 生产环境务必替换为随机长字符串（建议 64 位以上）
# 生成方式：openssl rand -base64 64
JWT_SECRET=请替换为你的随机密钥（至少64字符）
# Token 有效期（毫秒），86400000 = 24 小时
JWT_EXPIRATION=86400000

# ── 阿里云 DashScope AI 配置 ───────────────────────────────
# ⚠️ 必填项，前往 https://dashscope.console.aliyun.com/ 获取
# API Key 格式：sk-xxxxxxxxxxxxxxxx
DASHSCOPE_API_KEY=sk-你的阿里云DashScope密钥
# 模型名称（默认通义千问-plus，可按需修改）
DASHSCOPE_MODEL=qwen-plus
# API 地址（通常不需要修改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# ── 日志级别 ───────────────────────────────────────────────
# 可选值：TRACE, DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
